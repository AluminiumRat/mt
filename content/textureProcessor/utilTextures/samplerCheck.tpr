shader: samplerCheck.frag
output: samplerCheck.dds
outputFormat: VK_FORMAT_B8G8R8A8_SRGB
outputWidth: 1024
outputHeight: 1024
outputMips: 1
mipsAutogenerate: false
outputArraySize: 1
shaderProps:
  params.samplesCount:
    int: [16]
  params.startSample:
    int: [820]
  samplesTexture:
    file: ..\..\util\diskSampler1024.dds
  textureSampler:
    sampler:
      default: true