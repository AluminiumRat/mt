commonSetName : ColorFrameCommonSet

selections:
  INDICES_ENABLED: [0, 1]

passes:
  Prepass:
    selections: [INDICES_ENABLED]
    frameType: ColorFrame
    stageName: OpaquePrepass
    maxInstances: 32

    shaders:
      VERTEX : gltf/gltfPrepass.vert

    frameBuffer:
      depthStencil: VK_FORMAT_D32_SFLOAT_S8_UINT

    graphicSettings:
      topology: TRIANGLE_LIST
      cullMode : BACK
      depthTest : true
      depthWrite : true
      depthCompareOp : GREATER_OR_EQUAL
