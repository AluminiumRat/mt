commonSetName : ColorFrameCommonSet

defaultSamplers:
  nearestSampler:
    magFilter: NEAREST
    minFilter: NEAREST
    mipmapMode: NEAREST

passes:
  ResolvePass :
    shaders:
      VERTEX : lib/fsQuadCamera.vert
      FRAGMENT : shadows/resolve.frag

    frameBuffer:
      color: VK_FORMAT_R8_UNORM

    graphicSettings:
      topology: TRIANGLE_STRIP